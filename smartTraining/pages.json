{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "小链助手"
      }
    },
    {
      "path": "pages/sessions/sessions",
      "style": {
        "navigationBarTitleText": "对练记录"
      }
    }
  ],
  "subpackages": [
    {
      "root": "subpackages",
      "pages": [
        {
          "path": "session/session",
          "style": {
            "navigationBarTitleText": ""
          }
        },
        {
          "path": "evaluation/evaluation",
          "style": {
            "navigationBarTitleText": "评估结果"
          }
        },
        {
          "path": "customTraining/customTraining",
          "style": {
            "navigationBarTitleText": "对练设置"
          }
        },
        {
          "path": "profile/profile",
          "style": {
            "navigationBarTitleText": "客户画像"
          }
        }
      ],
      "independent": false
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["subpackages"]
    }
  },
  "tabBar": {
    "color": "#323233",
    "selectedColor": "#106cff",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "开始对练",
        "iconPath": "/static/chat.png",
        "selectedIconPath": "/static/chat-selected.png"
      },
      {
        "pagePath": "pages/sessions/sessions",
        "text": "对练记录",
        "iconPath": "/static/sessions.png",
        "selectedIconPath": "/static/sessions-selected.png"
      }
    ],
    "position": "bottom"
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "uni-app",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8",
    "app-plus": {
      "background": "#efeff4"
    }
  }
}
