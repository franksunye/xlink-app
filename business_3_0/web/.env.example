# 站点（可选）
# NEXT_PUBLIC_SITE_URL=https://xlink-app.vercel.app

# ---------------------------------------------------------------------------
# Cloud 只读（v0.2）— 本地 / CI 可拷贝本文件为 .env.local 再改
# ---------------------------------------------------------------------------
# Vercel 上若未设置下列两项，运行时会默认：开启 cloud 读 + Base 指向 beta（见 lib/work-order-cloud-read.ts）。
# 若要关闭该行为：在 Vercel 环境变量中加 XLINK_CLOUD_VERCEL_DEFAULTS=0
#
# USE_CLOUD_READ=1
# XLINK_CLOUD_READ_BASE_URL=https://xlinkbeta.fsgo365.cn/fsgo/wm

# 敏感项仅在 Vercel Dashboard / CLI 配置，勿提交仓库
# XLINK_CLOUD_READ_JSESSIONID=
# XLINK_CLOUD_READ_AUTH_TOKEN=
