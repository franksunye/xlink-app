    border-top: 4px solid #3498db;
    border-radius: 50%;
    transition-duration: 3s;
    transform: rotate(1800deg);
  }

  .loader_rotate {
    transform: rotate(1080deg); /* 三圈 */
  }

  .van_button:active {
    background-color: #ebedf0; /* 点击时背景变蓝色一点 */
