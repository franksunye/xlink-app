    top: 0px;
    left: 0px;
    z-index: 100;
  }

  .card_top {
    flex: 1;
    height: 24px;
  }

  .card_header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }
  .header_left {
    flex-direction: row;
    align-items: center;
  }
  .header_right {
    align-items: center;
  }
  .header_tag {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    align-items: center;
    justify-content: center;
  }
  .c-bg-red {
    background-color: #ee0a24;
  }
  .c-bg-blue {
    background-color: #1989fa;
  }
  .van_button {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0px 10px;
    border: 1px solid #ebedf0;
