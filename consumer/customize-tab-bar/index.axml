<view class="tab-bar">
  <view class="tab-bar-border"></view>
  <view a:for="{{list}}" a:key="index" class="tab-bar-item" data-pagepath="{{item.pagePath}}" data-index="{{index}}" onTap="{{item.pagePath == '/pages/message/message' ? 'openCustomerServiceChat' : 'switchTab'}}">
    <image class="tab-bar-icon" src="{{active === index ? item.selectedIconPath : item.iconPath}}"></image>
    <view class="tab-bar-text" style="color: {{active === index ? '#231815' : '#919191'}}">{{item.text}}</view>
  </view>
</view>