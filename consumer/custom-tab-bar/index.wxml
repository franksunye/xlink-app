<cover-view class="tab-bar">
  <cover-view class="tab-bar-border"></cover-view>
  <cover-view wx:for="{{list}}" wx:key="index" class="tab-bar-item" data-pagepath="{{item.pagePath}}" data-index="{{index}}" bindtap="{{item.pagePath == '/pages/message/message' ? 'openCustomerServiceChat' : 'switchTab'}}">
    <cover-image class="tab-bar-icon" src="{{active === index ? item.selectedIconPath : item.iconPath}}"></cover-image>
    <cover-view class="tab-bar-text" style="color: {{active === index ? '#231815' : '#919191'}}">{{item.text}}</cover-view>
  </cover-view>
</cover-view>